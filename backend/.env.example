# Copy to .env and fill values. Never commit .env (secrets).

# Option A — one line (local or Atlas paste from Atlas "Connect"):
# MONGODB_URI=mongodb://127.0.0.1:27017/it6006_finance
# MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/it6006_finance?retryWrites=true&w=majority

# Option B — Atlas split (host only = part after @ and before / in the connection string)
# MONGODB_USER=
# MONGODB_PASSWORD=
# MONGODB_CLUSTER_HOST=cluster0.xxxxx.mongodb.net
# MONGODB_DB_NAME=it6006_finance

# Server
PORT=5000
NODE_ENV=development

# Optional: lock CORS to the Vite UI in dev (default * allows any origin)
# CORS_ORIGIN=http://localhost:5173

# JWT: use a long random secret in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# Seed admin (created once if no admin exists — change password after first login)
SEED_ADMIN_EMAIL=moizranammf@gmail.com
SEED_ADMIN_PASSWORD=12345678
