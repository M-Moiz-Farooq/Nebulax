{
  "info": {
    "name": "IT6006 Enterprise Finance API",
    "description": "Sample requests for the secure finance backend. Set collection variables: baseUrl, token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@university.edu\",\n  \"password\": \"SecurePass1\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/signup"
          }
        },
        {
          "name": "POST /api/auth/login (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@enterprise.local\",\n  \"password\": \"ChangeMe123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "POST /api/auth/login (user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@university.edu\",\n  \"password\": \"SecurePass1\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Users (ADMIN)",
      "item": [
        {
          "name": "GET /api/users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/users"
          }
        },
        {
          "name": "POST /api/users (create ACCOUNTANT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"accountant@enterprise.local\",\n  \"password\": \"Accountant1\",\n  \"role\": \"ACCOUNTANT\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "GET /api/transactions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/transactions"
          }
        },
        {
          "name": "POST /api/transactions",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 150.5,\n  \"type\": \"credit\",\n  \"description\": \"Client payment — invoice #1001\",\n  \"date\": \"2026-04-01T10:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/api/transactions"
          }
        },
        {
          "name": "PUT /api/transactions/:id",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\",\n  \"amount\": 175\n}"
            },
            "url": "{{baseUrl}}/api/transactions/REPLACE_WITH_MONGO_ID"
          }
        },
        {
          "name": "DELETE /api/transactions/:id (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/transactions/REPLACE_WITH_MONGO_ID"
          }
        }
      ]
    },
    {
      "name": "Notes",
      "item": [
        {
          "name": "POST /api/notes/credit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 25,\n  \"description\": \"Credit note — pricing adjustment\",\n  \"reference\": \"CN-2026-001\"\n}"
            },
            "url": "{{baseUrl}}/api/notes/credit"
          }
        },
        {
          "name": "POST /api/notes/debit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 40,\n  \"description\": \"Debit note — additional charge\",\n  \"reference\": \"DN-2026-001\"\n}"
            },
            "url": "{{baseUrl}}/api/notes/debit"
          }
        }
      ]
    }
  ]
}
